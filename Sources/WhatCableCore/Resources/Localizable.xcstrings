        }
      }
    },
    "Legitimate USB-IF members ship cables with a non-zero vendor ID. A zeroed VID is a common counterfeit signature.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "合法的 USB-IF 成员出货的线缆带有非零供应商 ID。归零的 VID 是常见的假冒特征。"
          }
        }
      }
    },
    "Linked at %@": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "链接于 %@"
          }
        }
      }
    },
    "Negotiation hasn't completed yet.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "协商尚未完成。"
          }
        }
      }
    },
    "No USB-C / MagSafe ports were found on this Mac.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
