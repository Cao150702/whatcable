            "state": "translated",
            "value": "慢速 USB 设备或仅充电线缆"
          }
        }
      }
    },
    "Slow USB device or charge-only cable · %lldW charger": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
